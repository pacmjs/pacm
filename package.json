    "jest": "^29.7.0",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "deno": "^0.1.1",
    "node-fetch": "3.3.2",
    "ora": "^8.1.0",
    "prompts": "^2.4.2",
    "semver": "^7.6.3",
    "tar": "^7.4.3"
  }
