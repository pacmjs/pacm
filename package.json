{
  "name": "pacm-new",
  "version": "1.0.0",
  "description": "The ultimate javascript package manager",
  "main": "./core/pacm.js",
  "type": "module",
  "bin": {
    "pacm": "./core/pacm.js"
  },
  "scripts": {
    "build": "npm i . -g",
    "jest": "jest",
    "format": "prettier --write .",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "compile": "deno compile --unstable --allow-read --allow-write --allow-net --allow-run --allow-env --output dist/pacm ./core/pacm.js"
  },
